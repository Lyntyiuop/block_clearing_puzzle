/* === Game Container === */
.game-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  min-height: 100vh;
  background: #1a1a2e;
}

/* === Title === */
.title {
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 0.05em;
  color: #f0e6d3;
  text-shadow: 0 2px 8px rgba(0,0,0,0.4);
  margin-top: 10rpx;
}

/* === Level Indicator === */
.level-indicator {
  display: flex;
  align-items: center;
  gap: 32rpx;
  margin: 8rpx 0;
}

.level-btn {
  width: 64rpx;
  height: 64rpx;
  border: 2rpx solid rgba(255,255,255,0.2);
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
  color: #ccc;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.level-btn.disabled {
  opacity: 0.3;
}

.level-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #f0e6d3;
  min-width: 120rpx;
  text-align: center;
}

/* === Board Wrapper === */
.board-wrapper {
  display: flex;
  flex-direction: column;
  border-radius: 8rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.5);
}

/* === Borders === */
.border {
  flex-shrink: 0;
}

.border-top {
  width: 100%;
  background: #FF69B4;
  box-shadow: inset 0 -4rpx 8rpx rgba(0,0,0,0.2);
}

.border-bottom {
  width: 100%;
  background: #2d2d2d;
  box-shadow: inset 0 4rpx 8rpx rgba(0,0,0,0.3);
}

.border-left {
  background: #FFD700;
  box-shadow: inset -4rpx 0 8rpx rgba(0,0,0,0.2);
}

.border-right {
  background: #1a237e;
  box-shadow: inset 4rpx 0 8rpx rgba(0,0,0,0.2);
}

.middle-row {
  display: flex;
}

/* === Board Grid === */
.board {
  position: relative;
  background: #1a2744;
  overflow: hidden;
}

/* Grid lines omitted — ::after not well supported in mini-program.
   Plain dark background works well for the board. */

/* === Blocks === */
.block {
  position: absolute;
  border-radius: 4rpx;
  transition: transform 180ms cubic-bezier(0.25, 0.46, 0.45, 0.94), opacity 250ms ease-in;
  will-change: transform;
  box-shadow: inset 2px 2px 4px rgba(255,255,255,0.2),
              inset -2px -2px 4px rgba(0,0,0,0.3),
              0 1px 3px rgba(0,0,0,0.3);
  border: 1px solid rgba(255,255,255,0.1);
}

/* Block Colors */
.block-1 { background: #FFD700; }  /* Yellow */
.block-2 { background: #FF69B4; }  /* Pink */
.block-3 { background: #3d5afe; }  /* Dark Blue */
.block-4 { background: #4a4a4a; }  /* Black (dark gray for visibility) */

/* Elimination animation */
.block.eliminating {
  transform: scale(0) !important;
  opacity: 0;
}

/* === Status Bar === */
.status {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 48rpx;
  width: 100%;
  margin-top: 16rpx;
}

.move-counter {
  font-size: 30rpx;
  font-weight: 600;
  color: #c0c0c0;
}

.restart-btn {
  padding: 16rpx 48rpx;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 12rpx;
  background: #e94560;
  color: white;
  transition: background 150ms, transform 100ms;
}

.restart-btn:active {
  transform: scale(0.96);
  background: #c23152;
}

/* === Message === */
.message {
  font-size: 26rpx;
  color: #888;
  text-align: center;
  min-height: 1.4em;
  transition: color 300ms;
}

.message.success { color: #4caf50; }
.message.hint { color: #ff9800; }

/* === Win Overlay === */
.win-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 100;
}

.win-dialog {
  background: #1e2a3a;
  border-radius: 32rpx;
  padding: 80rpx 96rpx;
  text-align: center;
  box-shadow: 0 16rpx 80rpx rgba(0,0,0,0.5);
  animation: popIn 400ms cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

@keyframes popIn {
  from { transform: scale(0.7); opacity: 0; }
  to   { transform: scale(1); opacity: 1; }
}

.win-title {
  font-size: 48rpx;
  margin-bottom: 24rpx;
  color: #ffd700;
  font-weight: 700;
}

.win-moves {
  font-size: 30rpx;
  margin-bottom: 48rpx;
  color: #ccc;
}

.win-buttons {
  display: flex;
  justify-content: center;
  gap: 24rpx;
}

.next-btn {
  padding: 24rpx 72rpx;
  font-size: 30rpx;
  font-weight: 700;
  border-radius: 16rpx;
  background: #ff9800;
  color: white;
}

.next-btn:active {
  background: #e68900;
}

.again-btn {
  padding: 24rpx 72rpx;
  font-size: 30rpx;
  font-weight: 700;
  border-radius: 16rpx;
  background: #4caf50;
  color: white;
}

.again-btn:active {
  background: #388e3c;
}
